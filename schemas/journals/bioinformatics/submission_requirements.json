        "url": {
          "type": "string",
          "format": "uri",
          "description": "Journal homepage URL"
        },
        "submission_url": {
          "type": "string",
          "format": "uri",
          "description": "Submission guidelines URL"
        }
      }
    },
    "requirements": {
      "type": "object",
      "properties": {
