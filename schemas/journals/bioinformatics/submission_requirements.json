              "$ref": "#/$defs/word_limit"
            },
            "introduction": {
              "$ref": "#/$defs/word_limit"
            },
            "methods": {
              "$ref": "#/$defs/word_limit"
            },
            "results": {
              "$ref": "#/$defs/word_limit"
            },
            "discussion": {
              "$ref": "#/$defs/word_limit"
            },
            "total_manuscript": {
              "$ref": "#/$defs/word_limit"
            }
          }
        },
