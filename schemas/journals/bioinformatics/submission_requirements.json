          "description": "Required/optional sections and their constraints",
          "properties": {
            "required_sections": {
              "type": "array",
              "description": "Sections that must be present",
              "items": {
                "type": "string",
                "enum": [
                  "abstract",
                  "introduction",
                  "methods",
                  "results",
                  "discussion",
                  "availability",
                  "author_summary",
                  "acknowledgments",
                  "references"
                ]
              }
            },
            "optional_sections": {
              "type": "array",
              "description": "Sections that are optional",
              "items": {
                "type": "string"
              }
            },
            "section_order": {
              "type": "array",
              "description": "Required order of sections",
              "items": {
                "type": "string"
              }
            },
            "special_requirements": {
              "type": "object",
              "description": "Section-specific requirements",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "required_elements": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
