{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rrwrite.org/schemas/table_manifest.json",
  "title": "RRWrite Table Manifest",
  "description": "Schema for RRWrite table manifest files",
  "type": "object",
  "required": ["version", "created_at", "total_tables", "tables"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Manifest format version",
      "pattern": "^\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of manifest creation",
      "format": "date-time"
    },
    "total_tables": {
      "type": "integer",
      "description": "Total number of tables",
      "minimum": 0
    },
    "tables_from_repo": {
      "type": "integer",
      "description": "Number of tables extracted from repository",
      "minimum": 0
    },
    "tables_generated": {
      "type": "integer",
      "description": "Number of tables generated from analysis",
      "minimum": 0
    },
    "tables": {
      "type": "array",
      "description": "List of table metadata objects",
      "items": {
        "type": "object",
        "required": ["id", "path", "source", "priority", "recommended_sections", "default_caption"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique table identifier",
            "pattern": "^table_(repo|gen)_\\d{3}$"
          },
          "path": {
            "type": "string",
            "description": "Relative path to table file from manuscript directory"
          },
          "source": {
            "type": "string",
            "description": "Table source type",
            "enum": ["from_repo", "generated"]
          },
          "priority": {
            "type": "integer",
            "description": "Priority level (1=from_repo, 2=generated)",
            "minimum": 1,
            "maximum": 2
          },
          "original_path": {
            "type": "string",
            "description": "Original path in repository (for from_repo tables)"
          },
          "recommended_sections": {
            "type": "array",
            "description": "Manuscript sections where table is recommended",
            "items": {
              "type": "string",
              "enum": ["abstract", "introduction", "methods", "results", "discussion", "availability"]
            },
            "minItems": 1
          },
          "default_caption": {
            "type": "string",
            "description": "Default caption text for table",
            "minLength": 1
          },
          "generating_script": {
            "type": ["string", "null"],
            "description": "Script that generated this table (if identifiable)"
          }
        }
      }
    }
  }
}
