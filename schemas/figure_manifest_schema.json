{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rrwrite.org/schemas/figure_manifest.json",
  "title": "RRWrite Figure Manifest",
  "description": "Schema for RRWrite figure manifest files",
  "type": "object",
  "required": ["version", "created_at", "total_figures", "figures"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Manifest format version",
      "pattern": "^\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of manifest creation",
      "format": "date-time"
    },
    "total_figures": {
      "type": "integer",
      "description": "Total number of figures",
      "minimum": 0
    },
    "figures_from_repo": {
      "type": "integer",
      "description": "Number of figures extracted from repository",
      "minimum": 0
    },
    "figures_generated": {
      "type": "integer",
      "description": "Number of figures generated from analysis",
      "minimum": 0
    },
    "figures": {
      "type": "array",
      "description": "List of figure metadata objects",
      "items": {
        "type": "object",
        "required": ["id", "path", "source", "priority", "recommended_sections", "default_caption"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique figure identifier",
            "pattern": "^fig_(repo|gen)_\\d{3}$"
          },
          "path": {
            "type": "string",
            "description": "Relative path to figure file from manuscript directory"
          },
          "source": {
            "type": "string",
            "description": "Figure source type",
            "enum": ["from_repo", "generated"]
          },
          "priority": {
            "type": "integer",
            "description": "Priority level (1=from_repo, 2=generated)",
            "minimum": 1,
            "maximum": 2
          },
          "original_path": {
            "type": "string",
            "description": "Original path in repository (for from_repo figures)"
          },
          "recommended_sections": {
            "type": "array",
            "description": "Manuscript sections where figure is recommended",
            "items": {
              "type": "string",
              "enum": ["abstract", "introduction", "methods", "results", "discussion", "availability"]
            },
            "minItems": 1
          },
          "default_caption": {
            "type": "string",
            "description": "Default caption text for figure",
            "minLength": 1
          },
          "generating_script": {
            "type": ["string", "null"],
            "description": "Script that generated this figure (if identifiable)"
          }
        }
      }
    }
  }
}
